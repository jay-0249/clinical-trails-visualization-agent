# Copy to .env and fill in. .env is git-ignored.
# Values are also read from real environment variables (export OPENAI_API_KEY=...);
# a real env var overrides the .env file. Field names map case-insensitively to
# app/config.py Settings fields.

# --- LLM (OpenAI) ---
OPENAI_API_KEY=sk-...
LLM_MODEL_MAIN=gpt-4o             # Stage 1: query analysis (the planner)
LLM_MODEL_SUBAGENT=gpt-4o-mini   # Stage 4: viz generation + secondary LLM calls

# --- ClinicalTrials.gov API (no key required) ---
CT_API_BASE_URL=https://clinicaltrials.gov/api/v2
CT_API_PAGE_SIZE=1000            # always page at max
CT_API_MAX_PAGES=10              # 10 * 1000 = 10000 study ceiling
CT_API_TIMEOUT_SECONDS=30
CT_API_RATE_LIMIT_DELAY=1.2      # ~50 req/min ceiling

# --- Pipeline ---
MAX_STUDIES=5000                 # default cap; QueryRequest.max_studies overrides
LOG_LEVEL=INFO
