# Copy to .env and fill in. .env is git-ignored. Real env vars override this file.
# Field names map case-insensitively to app/config.py Settings.
# IMPORTANT: no inline (end-of-line) comments — `docker run --env-file` keeps them
# as part of the value. Put any comment on its own line.

# --- LLM (OpenAI) — one model per stage ---
OPENAI_API_KEY=sk-...
# Stage 1: planning (this key lacks the bare `gpt-4o` alias)
LLM_MODEL_QUERY_ANALYZER=gpt-4o-2024-08-06
# Stage 4: viz spec
LLM_MODEL_VIZ_GENERATOR=gpt-5.4-nano
# Stage 2.5: extraction (v2)
LLM_MODEL_EXTRACTOR=gpt-4o-mini

# --- ClinicalTrials.gov API (no key required) ---
CT_API_BASE_URL=https://clinicaltrials.gov/api/v2
CT_API_PAGE_SIZE=1000
CT_API_MAX_PAGES=10
CT_API_TIMEOUT_SECONDS=30
CT_API_RATE_LIMIT_DELAY=1.2

# --- Pipeline ---
MAX_STUDIES=5000
LOG_LEVEL=INFO
